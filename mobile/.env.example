# GeoCollect Field App — Environment Variables
# Copy to .env and fill in your values

# Backend API URL (default used if not set)
EXPO_PUBLIC_API_URL=https://api.geocollect.app

# Mapbox/MapLibre token (optional — for enhanced map tiles)
EXPO_PUBLIC_MAPBOX_TOKEN=

# EAS Project ID (from expo.dev)
EAS_PROJECT_ID=your-eas-project-id
